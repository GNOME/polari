#: data/metainfo/org.gnome.Polari.metainfo.xml.in:12 data/org.gnome.Polari.desktop.in:2
#: data/resources/main-window.ui:45 src/roomStack.js:279
msgid "Polari"
msgstr "Полари"

#: data/metainfo/org.gnome.Polari.metainfo.xml.in:13
msgid "Talk to people on IRC"
msgstr "Разговарајте са другима преко ИРЦ-а"

#: data/metainfo/org.gnome.Polari.metainfo.xml.in:66
msgid ""
"A simple Internet Relay Chat (IRC) client that is designed to integrate seamlessly with GNOME; it "
"features a simple and beautiful interface which allows you to focus on your conversations."
msgstr ""
"Једноставан клијент за ћаскање пренешено интернетом (ИРЦ) који је направљен са намером да буде "
"неприметно сједињен са Гномом. Одликује га једноставно и лепо сучеље које вам омогућава да се "
"усредсредите на ваше разговоре."

#: data/metainfo/org.gnome.Polari.metainfo.xml.in:71
msgid ""
"You can use Polari to publicly chat with people in a channel, and to have private one-to-one "
"conversations. Notifications make sure that you never miss an important message."
msgstr ""
"Можете користити Полари да бисте јавно причали са људима на каналима и да бисте имали приватне "
"разговоре у четири ока. Обавештења су ту за све важне поруке."

#: data/org.gnome.Polari.desktop.in:3
msgid "An Internet Relay Chat Client for GNOME"
msgstr "Гномов ИРЦ клијент за ћаскање"

